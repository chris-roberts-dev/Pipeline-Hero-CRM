{
  "name": "mypipelinehero-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env VITE_ENABLE_API_MOCKS=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "openapi:types": "npx openapi-typescript ./contracts/internal-api.openapi.yaml --output ./src/lib/api/generated/schema.d.ts",
    "openapi:types:remote": "node ./scripts/generate-openapi.mjs",
    "mocks:init": "npx msw init public/ --save",
    "mock:prism": "npx @stoplight/prism-cli mock ./contracts/internal-api.openapi.yaml"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "^7.0.0",
    "msw": "^2.0.0",
    "openapi-typescript": "^7.0.0",
    "@stoplight/prism-cli": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0"
  }
}
