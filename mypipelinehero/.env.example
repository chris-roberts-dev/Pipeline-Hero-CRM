# =============================================================================
# MyPipelineHero CRM — Environment Configuration
# =============================================================================
# Copy this file to `.env` at the repo root and adjust values.
# `.env` is gitignored; `.env.example` is the source of truth for what's
# configurable. Every setting referenced in config/settings/*.py must appear
# here with a comment explaining what it does.
# =============================================================================


# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------

# Which settings module to load. Almost always overridden in docker-compose
# or deployment env; the default here is for running manage.py directly.
#   - config.settings.dev   local development
#   - config.settings.test  automated tests
#   - config.settings.prod  production
DJANGO_SETTINGS_MODULE=config.settings.dev

# Cryptographic signing key for sessions, CSRF tokens, password resets, and
# handoff tokens. MUST be unique per environment. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=change-me-before-first-run-use-secrets-token_urlsafe-64

# Enables DEBUG mode. Never true in production.
DJANGO_DEBUG=True

# Comma-separated hosts Django will accept. The leading dot on ".localhost"
# means "any subdomain of localhost", which is what enables wildcard tenant
# subdomain routing in dev. In prod, list exact hostnames.
DJANGO_ALLOWED_HOSTS=.localhost,127.0.0.1,0.0.0.0

# Root domain serving the login landing page. Tenant portals live at
# {slug}.{MPH_ROOT_DOMAIN}. Keep in sync with DJANGO_ALLOWED_HOSTS.
MPH_ROOT_DOMAIN=mypipelinehero.localhost

# Prod-only: comma-separated origins trusted for CSRF (must include scheme).
# In dev, dev.py provides sane defaults; leave this unset.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://mypipelinehero.com,https://*.mypipelinehero.com


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full DB URL used by Django. `postgres` is the compose service name.
# In prod, point this at pgBouncer, not directly at Postgres.
DATABASE_URL=postgres://mph:mph@postgres:5432/mph

# Credentials for the postgres container itself. Must match DATABASE_URL.
POSTGRES_DB=mph
POSTGRES_USER=mph
POSTGRES_PASSWORD=mph

# Persistent connection lifetime (seconds). 0 = reconnect per request.
# Leave at 0 with pgBouncer in transaction pooling mode.
DJANGO_CONN_MAX_AGE=0


# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------

# Base Redis URL. Logical DB slots are appended in settings:
#   /0 cache, /1 celery broker, /2 celery results, /3 handoff tokens, /15 tests
REDIS_URL=redis://redis:6379


# -----------------------------------------------------------------------------
# Security (prod)
# -----------------------------------------------------------------------------
# These are enforced in prod settings. Overriding them in dev is rarely useful.

DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# HSTS max-age in seconds. 31536000 = 1 year. Only applied in prod.
DJANGO_SECURE_HSTS_SECONDS=31536000


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Root log level. DEBUG is chatty; INFO is fine for most dev work.
DJANGO_LOG_LEVEL=INFO

# Set True to log every SQL query django.db.backends runs. Useful for N+1
# hunting; impractically noisy otherwise.
DJANGO_LOG_SQL=False


# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Dev defaults to the console backend regardless of this setting.
# Prod email provider selection is an open decision (Open Decision #3) —
# update these once picked.

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@mypipelinehero.localhost
DJANGO_SERVER_EMAIL=errors@mypipelinehero.localhost


# -----------------------------------------------------------------------------
# Object storage (prod only — M5 onward)
# -----------------------------------------------------------------------------
# Per spec §24.6: local filesystem in dev, S3-compatible in prod.
# Leave these unset in dev; the FileSystemStorage default handles it.

# AWS_STORAGE_BUCKET_NAME=mph-prod-attachments
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=                   # Custom endpoint for R2/B2/MinIO; blank for AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=


# -----------------------------------------------------------------------------
# Sentry (prod only — required before first tenant production launch)
# -----------------------------------------------------------------------------

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=                        # Typically the git SHA
# SENTRY_TRACES_SAMPLE_RATE=0.0          # 0.0 disables perf tracing
