# Keeps the Docker build context small and avoids leaking local state.

.git/
.gitignore
.env
.env.*
!.env.example

__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

.idea/
.vscode/
.DS_Store

/staticfiles/
/media/
db.sqlite3*

frontend/node_modules/
frontend/dist/
